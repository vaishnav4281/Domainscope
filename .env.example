# ==============================================
# 🎨 FRONTEND CONFIGURATION (Vite)
# ==============================================
# Variables must start with VITE_ to be exposed to the browser.

# API Connection (REQUIRED)
VITE_API_URL="http://localhost:3001"

# --- Optional: Dev Proxy Configuration ---
# Used by Vite Dev Server to proxy requests if backend is down.
# The backend also checks these VITE_ keys as a fallback if backend keys are missing.
VITE_VIRUSTOTAL_API_KEY=your_vt_key
VITE_IPQS_API_KEY=your_ipqs_key
VITE_ABUSEIPDB_API_KEY=your_abuseipdb_key


# ==============================================
# ⚙️ BACKEND CONFIGURATION (Node.js)
# ==============================================
# These variables are for the backend server only.

# Server Config
PORT=3001
FRONTEND_URL="http://localhost:5173"
JWT_SECRET="supersecretkey123"

# Rate Limiting Configuration
# ---------------------------
# Controls the maximum number of requests allowed within a specific time window.

# Global Rate Limit: Applies to ALL API requests (scans, history, etc.)
# Prevents DDoS and general abuse of the server.
RATE_LIMIT_WINDOW_MS=900000 # Time window in milliseconds (15 minutes)
RATE_LIMIT_MAX=10000        # Max requests per IP per window (Local: 10000, Prod: 300)

# Auth Rate Limit: Applies ONLY to Login, Signup, and OTP verification
# Prevents brute-force password guessing and OTP spam.
AUTH_RATE_LIMIT_WINDOW_MS=3600000 # Time window in milliseconds (1 hour)
AUTH_RATE_LIMIT_MAX=10000         # Max auth attempts per IP per window (Local: 10000, Prod: 10)

# Database & Cache
# DATABASE_URL="postgresql://..." (Set automatically by Prisma/Render)
REDIS_URL="redis://default:..."

# Email Service (Resend)
RESEND_API_KEY="re_..."

# ==============================================
# 🔑 BACKEND API KEYS (Preferred)
# ==============================================
# Explicit keys for backend services.
# If these are not set, the backend will try to use the VITE_ keys above.

# VirusTotal (Supports rotation)
VT_API_KEY=your_vt_key_backend
VT_API_KEY_2=optional_backup_key

# IPQualityScore (Supports rotation)
IPQS_API_KEY=your_ipqs_key_backend

# AbuseIPDB (Supports rotation)
ABUSEIPDB_API_KEY=your_abuseipdb_key_backend
